<%- include('layout', { 
  title: 'POS Satış',
  body: `
    <div class="pos-container">
      <div class="left">
        <h2>💰 Satış</h2>
        
        <div class="search-section">
          <input type="text" id="barcodeInput" placeholder="Barkodu oku veya ürün adı/barkod yazarak ara...">
          <div id="searchResults" class="search-results"></div>
        </div>

        <div id="cartSection" style="display:none;">
          <h3>🛒 Sepet</h3>
          <div id="cartItems"></div>
          <div class="cart-summary">
            <p>Toplam: <strong id="totalPrice">0,00 TL</strong></p>
            <select id="paymentMethod">
              <option value="Nakit">💵 Nakit</option>
              <option value="Kredi Kartı">💳 Kredi Kartı</option>
              <option value="Çek">📄 Çek</option>
            </select>
            <button class="btn btn-primary" onclick="completeSale()">✅ Satışı Tamamla</button>
          </div>
        </div>
      </div>

      <div class="right">
        <h2>📊 Son Satışlar</h2>
        <div id="recentSales" class="recent-sales"></div>
      </div>
    </div>

    <script>
      const categoryLabels = {
        'Çocuk Giyim': (size) => `${size} Yaş`,
        'default': (size) => size
      };

      let cart = [];
      let selectedProduct = null;

      document.getElementById('barcodeInput').addEventListener('input', async (e) => {
        const search = e.target.value.toLowerCase();
        if (search.length < 1) {
          document.getElementById('searchResults').innerHTML = '';
          return;
        }

        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          
          const matches = products.filter(p => 
            p.barcode.includes(search) || p.name.toLowerCase().includes(search)
          );

          let html = '';
          matches.forEach(p => {
            html += `<div class="product-result" onclick="selectProduct('${p._id}')" style="cursor:pointer;padding:10px;border-bottom:1px solid #ddd;">
              <strong>${p.name}</strong> - ${p.category}
              <br><small>${p.barcode} | ${p.price.toFixed(2)} TL</small>
            </div>`;
          });
          
          document.getElementById('searchResults').innerHTML = html;
        } catch (error) {
          console.error('Ürün arama hatası:', error);
        }
      });

      window.selectProduct = async (productId) => {
        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          selectedProduct = products.find(p => p._id === productId);
          
          document.getElementById('searchResults').innerHTML = '';
          document.getElementById('barcodeInput').value = selectedProduct.name;
          
          showSizeSelection();
        } catch (error) {
          console.error('Ürün yükleme hatası:', error);
        }
      };

      function showSizeSelection() {
        const sizes = selectedProduct.sizeStock;
        const formatter = categoryLabels[selectedProduct.category] || categoryLabels['default'];
        
        let html = `<h4>Beden Seç (${selectedProduct.name}):</h4>`;
        sizes.forEach(s => {
          const display = formatter(s.size);
          const disabled = s.stock === 0 ? 'disabled' : '';
          html += `<button onclick="addToCart('${selectedProduct._id}', '${s.size}')" ${disabled} class="btn" style="margin-bottom:5px;">
            ${display} (Stok: ${s.stock})
          </button>`;
        });
        
        document.getElementById('searchResults').innerHTML = html;
      }

      window.addToCart = async (productId, size) => {
        const product = await fetch(`/api/products`).then(r => r.json()).then(ps => ps.find(p => p._id === productId));
        const sizeItem = product.sizeStock.find(s => s.size === size);
        const formatter = categoryLabels[product.category] || categoryLabels['default'];
        
        cart.push({
          productId: productId,
          productName: product.name,
          category: product.category,
          size: size,
          sizeDisplay: formatter(size),
          price: product.price,
          quantity: 1
        });
        
        document.getElementById('cartSection').style.display = 'block';
        document.getElementById('searchResults').innerHTML = '';
        document.getElementById('barcodeInput').value = '';
        selectedProduct = null;
        
        updateCart();
      };

      function updateCart() {
        let html = '';
        let total = 0;
        
        cart.forEach((item, idx) => {
          const itemTotal = item.price * item.quantity;
          total += itemTotal;
          html += `<div class="cart-item">
            <span>${item.productName} (${item.sizeDisplay}) x${item.quantity}</span>
            <span>${itemTotal.toFixed(2)} TL</span>
            <button onclick="removeFromCart(${idx})" class="btn btn-small">🗑️</button>
          </div>`;
        });
        
        document.getElementById('cartItems').innerHTML = html;
        document.getElementById('totalPrice').textContent = total.toFixed(2).replace('.', ',') + ' TL';
      }

      window.removeFromCart = (idx) => {
        cart.splice(idx, 1);
        if (cart.length === 0) {
          document.getElementById('cartSection').style.display = 'none';
        }
        updateCart();
      };

      window.completeSale = async () => {
        if (cart.length === 0) {
          alert('Sepet boş!');
          return;
        }

        for (let item of cart) {
          try {
            await fetch('/api/sales', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                productId: item.productId,
                size: item.size,
                quantity: item.quantity,
                paymentMethod: document.getElementById('paymentMethod').value,
                cashier: 'POS'
              })
            });
          } catch (error) {
            alert('Satış hatası: ' + error.message);
            return;
          }
        }
        
        alert('✅ Satış başarılı!');
        cart = [];
        document.getElementById('cartSection').style.display = 'none';
        document.getElementById('cartItems').innerHTML = '';
        loadRecentSales();
      };

      async function loadRecentSales() {
        try {
          const response = await fetch('/api/sales-history');
          const sales = await response.json();
          
          let html = '';
          sales.slice(0, 10).forEach(sale => {
            const formatter = categoryLabels[sale.category] || categoryLabels['default'];
            const sizeDisplay = formatter(sale.size);
            html += `<div class="recent-sale-item">
              <strong>${sale.productName}</strong><br>
              Beden: ${sizeDisplay} | Miktar: ${sale.quantity}<br>
              <small>${new Date(sale.createdAt).toLocaleString('tr-TR')}</small>
            </div>`;
          });
          
          document.getElementById('recentSales').innerHTML = html;
        } catch (error) {
          console.error('Satış geçmişi yükleme hatası:', error);
        }
      }

      loadRecentSales();
      setInterval(loadRecentSales, 5000);
    </script>
  `
}) %>