<%- include('layout', { 
  title: 'POS Satış',
  body: `
    <div class="pos-container">
      <div class="pos-header">
        <h2>💰 Hızlı Satış Ekranı (POS)</h2>
        <p>Barkodu okutun veya manuel olarak girin</p>
      </div>

      <div id="notification" class="notification hidden"></div>

      <div class="pos-main">
        <div class="pos-left">
          <form id="salesForm" class="sales-form">
            <div class="form-group">
              <label for="barcodeInput">Barkod Numarası</label>
              <input 
                type="text" 
                id="barcodeInput" 
                name="barcode"
                placeholder="Barkod okutun..."
                autofocus
                autocomplete="off"
              >
            </div>
          </form>

          <div class="sales-info">
            <h3>Son İşlemler</h3>
            <div id="transactionLog" class="transaction-log">
              <p class="placeholder">Henüz işlem yapılmamış</p>
            </div>
          </div>
        </div>

        <div class="pos-right">
          <div class="cart-section">
            <h3>🛒 Alışveriş Sepeti</h3>
            
            <div id="cartItems" class="cart-items">
              <p class="placeholder">Sepet boş</p>
            </div>

            <div class="cart-summary">
              <div class="summary-row">
                <span>Ara Toplam:</span>
                <strong id="subtotal">0,00 ₺</strong>
              </div>
              <div class="summary-row">
                <label for="discountInput">İndirim (%):</label>
                <input type="number" id="discountInput" min="0" max="100" value="0" step="0.1" placeholder="0">
              </div>
              <div class="summary-row discount">
                <span>İndirim Tutarı:</span>
                <strong id="discountAmount">0,00 ₺</strong>
              </div>
              <div class="summary-row total">
                <span>TOPLAM:</span>
                <strong id="totalPrice">0,00 ₺</strong>
              </div>
              <div class="summary-row">
                <label for="paymentMethod">Ödeme Yöntemi:</label>
                <select id="paymentMethod" style="width:120px;padding:0.4rem;">
                  <option value="Nakit">Nakit</option>
                  <option value="Kart">Kredi Kartı</option>
                  <option value="Havale">Havale</option>
                </select>
              </div>
              <button type="button" id="checkoutBtn" class="btn btn-primary btn-full">✓ Ödeme Al</button>
              <button type="button" id="clearCartBtn" class="btn btn-secondary btn-full">🗑️ Sepeti Temizle</button>
            </div>
          </div>
        </div>
      </div>

      <div class="pos-footer">
        <p>Sistem Hazır | ✓ Barkod okuyucu bağlı</p>
      </div>
    </div>

    <!-- Beden Seçim Modal -->
    <div id="sizeModal" class="modal hidden">
      <div class="modal-content" style="max-width:420px;">
        <button class="close" onclick="closeSizeModal()">&times;</button>
        <h3 id="sizeModalTitle" style="margin-bottom:0.5rem;color:var(--primary-color);"></h3>
        <p id="sizeModalSubtitle" style="color:#6b7280;margin-bottom:1.2rem;font-size:0.9rem;"></p>
        <div id="sizeButtons" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:0.6rem;margin-bottom:1rem;"></div>
        <button class="btn btn-secondary" onclick="closeSizeModal()" style="width:100%;">İptal</button>
      </div>
    </div>

    <script>
      const salesForm = document.getElementById('salesForm');
      const barcodeInput = document.getElementById('barcodeInput');
      const notification = document.getElementById('notification');
      const cartItemsContainer = document.getElementById('cartItems');
      const discountInput = document.getElementById('discountInput');
      const checkoutBtn = document.getElementById('checkoutBtn');
      const clearCartBtn = document.getElementById('clearCartBtn');
      const transactionLog = document.getElementById('transactionLog');

      let cart = [];
      let transactions = [];
      let pendingProduct = null;

      // Barkod okutma
      salesForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const barcode = barcodeInput.value.trim();

        if (!barcode) {
          showNotification('Lütfen barkod girin', 'error');
          barcodeInput.focus();
          return;
        }

        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          const product = products.find(p => p.barcode === barcode);

          if (!product) {
            showNotification('Hata: Ürün bulunamadı', 'error');
          } else {
            const totalStock = product.sizeStock.reduce((s, i) => s + i.stock, 0);
            if (totalStock <= 0) {
              showNotification('Hata: Tüm bedenlerde stok tükendi', 'error');
            } else if (product.sizeStock.length === 1 && product.sizeStock[0].size === 'Tek Boyut') {
              // Tek boyutlu ürün - direkt sepete ekle
              addToCart(product, 'Tek Boyut');
              showNotification(\`✓ \${product.name} sepete eklendi\`, 'success');
            } else {
              // Beden seçimi gerekiyor
              openSizeModal(product);
            }
          }
        } catch (error) {
          showNotification('Hata: ' + error.message, 'error');
        } finally {
          barcodeInput.value = '';
          barcodeInput.focus();
        }
      });

      function openSizeModal(product) {
        pendingProduct = product;
        const isAge = product.category === 'Çocuk Giyim';

        document.getElementById('sizeModalTitle').textContent = product.name;
        document.getElementById('sizeModalSubtitle').textContent = isAge
          ? 'Yaş grubu seçin:'
          : 'Beden seçin:';

        const container = document.getElementById('sizeButtons');
        container.innerHTML = '';

        product.sizeStock.forEach(s => {
          const label = isAge ? \`\${s.size} Yaş\` : s.size;
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.style.cssText = \`padding:0.6rem 0.4rem;border-radius:6px;border:2px solid;font-size:0.85rem;font-weight:600;cursor:pointer;transition:all 0.2s;\${
            s.stock === 0
              ? 'border-color:#e5e7eb;background:#f3f4f6;color:#9ca3af;cursor:not-allowed;'
              : 'border-color:var(--primary-color);background:white;color:var(--primary-color);'
          }\`;
          btn.disabled = s.stock === 0;
          btn.innerHTML = \`<div>\${label}</div><div style="font-size:0.75rem;margin-top:2px;">\${s.stock === 0 ? 'Stok yok' : s.stock + ' adet'}</div>\`;
          if (s.stock > 0) {
            btn.addEventListener('mouseover', () => {
              btn.style.background = 'var(--primary-color)';
              btn.style.color = 'white';
            });
            btn.addEventListener('mouseout', () => {
              btn.style.background = 'white';
              btn.style.color = 'var(--primary-color)';
            });
            btn.addEventListener('click', () => {
              closeSizeModal();
              addToCart(product, s.size);
              const displayLabel = isAge ? \`\${s.size} Yaş\` : s.size;
              showNotification(\`✓ \${product.name} (\${displayLabel}) sepete eklendi\`, 'success');
            });
          }
          container.appendChild(btn);
        });

        document.getElementById('sizeModal').classList.remove('hidden');
      }

      function closeSizeModal() {
        document.getElementById('sizeModal').classList.add('hidden');
        pendingProduct = null;
        barcodeInput.focus();
      }

      document.getElementById('sizeModal').addEventListener('click', function(e) {
        if (e.target === this) closeSizeModal();
      });

      function addToCart(product, size) {
        const cartKey = \`\${product._id}_\${size}\`;
        const existingItem = cart.find(item => item._cartKey === cartKey);
        const sizeItem = product.sizeStock.find(s => s.size === size);
        const availableStock = sizeItem ? sizeItem.stock : 0;

        if (existingItem) {
          if (existingItem.quantity < availableStock) {
            existingItem.quantity += 1;
          } else {
            showNotification('Stok sınırına ulaştınız', 'error');
          }
        } else {
          const isAge = product.category === 'Çocuk Giyim';
          cart.push({
            ...product,
            _cartKey: cartKey,
            selectedSize: size,
            sizeDisplay: isAge ? size + ' Yaş' : size,
            availableStock,
            quantity: 1
          });
        }

        updateCart();
      }

      function updateCart() {
        cartItemsContainer.innerHTML = '';

        if (cart.length === 0) {
          cartItemsContainer.innerHTML = '<p class="placeholder">Sepet boş</p>';
        } else {
          cart.forEach(item => {
            const itemTotal = item.price * item.quantity;
            const cartItem = document.createElement('div');
            cartItem.className = 'cart-item';
            cartItem.innerHTML = \`
              <div class="cart-item-info">
                <p class="cart-item-name">\${item.name}</p>
                <p class="cart-item-price">\${item.price.toFixed(2)} ₺ • <span style="color:var(--primary-color);font-weight:600;">\${item.sizeDisplay}</span></p>
              </div>
              <div class="cart-item-controls">
                <button type="button" onclick="decreaseQuantity('\${item._cartKey}')" class="qty-btn">−</button>
                <input type="number" value="\${item.quantity}" readonly class="qty-input">
                <button type="button" onclick="increaseQuantity('\${item._cartKey}')" class="qty-btn">+</button>
              </div>
              <div class="cart-item-total">
                <p>\${itemTotal.toFixed(2)} ₺</p>
                <button type="button" onclick="removeFromCart('\${item._cartKey}')" class="btn-remove">🗑️</button>
              </div>
            \`;
            cartItemsContainer.appendChild(cartItem);
          });
        }

        updateSummary();
      }

      function increaseQuantity(cartKey) {
        const item = cart.find(i => i._cartKey === cartKey);
        if (item && item.quantity < item.availableStock) {
          item.quantity += 1;
          updateCart();
        }
      }

      function decreaseQuantity(cartKey) {
        const item = cart.find(i => i._cartKey === cartKey);
        if (item && item.quantity > 1) {
          item.quantity -= 1;
          updateCart();
        }
      }

      function removeFromCart(cartKey) {
        cart = cart.filter(item => item._cartKey !== cartKey);
        updateCart();
      }

      function updateSummary() {
        const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
        const discountPercent = parseFloat(discountInput.value) || 0;
        const discountAmount = subtotal * (discountPercent / 100);
        const total = subtotal - discountAmount;

        document.getElementById('subtotal').textContent = subtotal.toFixed(2).replace('.', ',') + ' ₺';
        document.getElementById('discountAmount').textContent = discountAmount.toFixed(2).replace('.', ',') + ' ₺';
        document.getElementById('totalPrice').textContent = total.toFixed(2).replace('.', ',') + ' ₺';
      }

      discountInput.addEventListener('change', updateSummary);
      discountInput.addEventListener('input', updateSummary);

      clearCartBtn.addEventListener('click', () => {
        if (confirm('Sepeti temizlemek istediğinize emin misiniz?')) {
          cart = [];
          updateCart();
          showNotification('Sepet temizlendi', 'success');
        }
      });

      checkoutBtn.addEventListener('click', async () => {
        if (cart.length === 0) {
          showNotification('Sepet boş', 'error');
          return;
        }

        const paymentMethod = document.getElementById('paymentMethod').value;

        try {
          for (const item of cart) {
            const response = await fetch('/api/satis', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ 
                barcode: item.barcode,
                size: item.selectedSize,
                quantity: item.quantity,
                paymentMethod
              })
            });

            const data = await response.json();
            if (!data.success) {
              throw new Error(data.message);
            }
          }

          const subtotal = cart.reduce((sum, item) => sum + (item.price * item.quantity), 0);
          const discountPercent = parseFloat(discountInput.value) || 0;
          const discountAmount = subtotal * (discountPercent / 100);
          const total = subtotal - discountAmount;

          showNotification(\`✓ Satış tamamlandı. Toplam: \${total.toFixed(2)} ₺\`, 'success');
          
          addTransaction(cart, total);
          cart = [];
          discountInput.value = 0;
          updateCart();
        } catch (error) {
          showNotification('Ödeme hatası: ' + error.message, 'error');
        }
      });

      function addTransaction(items, total) {
        const time = new Date().toLocaleTimeString('tr-TR');
        const transaction = {
          time,
          items: items.map(i => \`\${i.name} (\${i.sizeDisplay})\`).join(', '),
          total,
          itemCount: items.length
        };

        transactions.unshift(transaction);
        if (transactions.length > 5) transactions.pop();

        updateTransactionLog();
      }

      function updateTransactionLog() {
        if (transactions.length === 0) {
          transactionLog.innerHTML = '<p class="placeholder">Henüz işlem yapılmamış</p>';
          return;
        }

        transactionLog.innerHTML = transactions
          .map(t => \`
            <div class="transaction-item success">
              <span class="icon">✓</span>
              <span class="time">\${t.time}</span>
              <span class="product">\${t.items}</span>
              <span class="price">\${t.total.toFixed(2)} ₺</span>
            </div>
          \`)
          .join('');
      }

      function showNotification(message, type) {
        notification.textContent = message;
        notification.className = 'notification ' + type;
        notification.classList.remove('hidden');

        setTimeout(() => {
          notification.classList.add('hidden');
        }, 4000);
      }

      updateCart();
    </script>
  ` 
}) %>

