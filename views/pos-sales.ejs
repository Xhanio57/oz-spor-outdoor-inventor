<%- include('layout', { 
  title: 'POS Satış',
  body: `
    <div class="pos-container" style="display: flex; gap: 20px; padding: 20px;">
      <div class="left" style="flex: 1; border-right: 1px solid #ddd; padding-right: 20px;">
        <h2 style="margin-bottom: 20px;">💰 Satış</h2>
        
        <div class="search-section" style="margin-bottom: 20px;">
          <input type="text" id="barcodeInput" placeholder="Barkodu oku veya ürün adı yazarak ara..." style="width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 4px; font-size: 16px;">
          <div id="searchResults" style="margin-top: 10px; max-height: 300px; overflow-y: auto; border: 1px solid #eee; border-radius: 4px;"></div>
        </div>

        <div id="cartSection" style="display:none;">
          <h3>🛒 Sepet</h3>
          <div id="cartItems" style="margin-bottom: 15px; border-top: 2px solid #ddd; padding-top: 10px;"></div>
          <div class="cart-summary" style="background: #f0f0f0; padding: 15px; border-radius: 4px;">
            <p style="font-size: 18px; margin-bottom: 15px;">Toplam: <strong id="totalPrice" style="color: #10b981;">0,00 TL</strong></p>
            <select id="paymentMethod" style="width: 100%; padding: 10px; margin-bottom: 10px; border: 1px solid #ccc; border-radius: 4px;">
              <option value="Nakit">💵 Nakit</option>
              <option value="Kredi Kartı">💳 Kredi Kartı</option>
              <option value="Çek">📄 Çek</option>
            </select>
            <button onclick="completeSale()" class="btn btn-primary" style="width: 100%; padding: 12px; background: #10b981; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; font-size: 16px;">✅ Satışı Tamamla</button>
          </div>
        </div>
      </div>

      <div class="right" style="flex: 1;">
        <h2 style="margin-bottom: 20px;">📊 Son Satışlar</h2>
        <div id="recentSales" style="border: 1px solid #eee; border-radius: 4px; padding: 15px; max-height: 600px; overflow-y: auto;"></div>
      </div>
    </div>

    <script>
      let cart = [];

      document.getElementById('barcodeInput').addEventListener('input', async (e) => {
        const search = e.target.value.toLowerCase();
        if (search.length < 1) {
          document.getElementById('searchResults').innerHTML = '';
          return;
        }

        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          
          const matches = products.filter(p => 
            p.barcode.toLowerCase().includes(search) || p.name.toLowerCase().includes(search)
          );

          let html = '';
          matches.slice(0, 5).forEach(p => {
            html += `<div onclick="selectProduct('${p._id}')" style="padding:10px; border-bottom:1px solid #eee; cursor:pointer; hover-background: #f0f0f0;">
              <strong>${p.name}</strong> (${p.category})<br>
              <small>${p.barcode} | ${p.price.toFixed(2)} TL</small>
            </div>`;
          });
          
          if (matches.length === 0) html = '<div style="padding:10px; color:#999;">Ürün bulunamadı</div>';
          document.getElementById('searchResults').innerHTML = html;
        } catch (error) {
          console.error('Arama hatası:', error);
        }
      });

      window.selectProduct = async (productId) => {
        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          const product = products.find(p => p._id === productId);
          
          document.getElementById('searchResults').innerHTML = '';
          document.getElementById('barcodeInput').value = product.name;
          
          let html = `<h4 style="margin-bottom: 10px;">Beden Seç (${product.name}):</h4>`;
          product.sizeStock.forEach(s => {
            const sizeDisplay = product.category === 'Çocuk Giyim' ? (s.size + ' Yaş') : s.size;
            const disabled = s.stock === 0 ? 'disabled' : '';
            const btnStyle = s.stock === 0 ? 'background: #ccc; cursor: not-allowed;' : 'background: #2563eb; cursor: pointer;';
            html += `<button onclick="addToCart('${productId}', '${s.size}')" ${disabled} style="display: block; width: 100%; padding: 8px; margin: 8px 0; color: white; border: none; border-radius: 4px; ${btnStyle}">
              ${sizeDisplay} (Stok: ${s.stock})
            </button>`;
          });
          
          document.getElementById('searchResults').innerHTML = html;
        } catch (error) {
          console.error('Ürün yükleme hatası:', error);
        }
      };

      window.addToCart = async (productId, size) => {
        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          const product = products.find(p => p._id === productId);
          const sizeDisplay = product.category === 'Çocuk Giyim' ? (size + ' Yaş') : size;
          
          cart.push({
            productId: productId,
            productName: product.name,
            category: product.category,
            size: size,
            sizeDisplay: sizeDisplay,
            price: product.price,
            quantity: 1
          });
          
          document.getElementById('cartSection').style.display = 'block';
          document.getElementById('searchResults').innerHTML = '';
          document.getElementById('barcodeInput').value = '';
          updateCart();
        } catch (error) {
          console.error('Sepete ekleme hatası:', error);
        }
      };

      function updateCart() {
        let html = '';
        let total = 0;
        
        cart.forEach((item, idx) => {
          const itemTotal = item.price * item.quantity;
          total += itemTotal;
          html += `<div style="padding: 10px; background: white; margin-bottom: 8px; border-radius: 4px; display: flex; justify-content: space-between; align-items: center;">
            <div>
              <strong>${item.productName}</strong><br>
              <small>${item.sizeDisplay} x${item.quantity} = ${itemTotal.toFixed(2)} TL</small>
            </div>
            <button onclick="removeFromCart(${idx})" class="btn btn-small" style="background: #dc2626; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;">🗑️</button>
          </div>`;
        });
        
        document.getElementById('cartItems').innerHTML = html;
        document.getElementById('totalPrice').textContent = total.toFixed(2).replace('.', ',') + ' TL';
      }

      window.removeFromCart = (idx) => {
        cart.splice(idx, 1);
        if (cart.length === 0) {
          document.getElementById('cartSection').style.display = 'none';
        }
        updateCart();
      };

      window.completeSale = async () => {
        if (cart.length === 0) {
          alert('❌ Sepet boş!');
          return;
        }

        for (let item of cart) {
          try {
            const response = await fetch('/api/sales', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                productId: item.productId,
                size: item.size,
                quantity: item.quantity,
                paymentMethod: document.getElementById('paymentMethod').value,
                cashier: 'POS'
              })
            });
            if (!response.ok) throw new Error('Satış başarısız');
          } catch (error) {
            alert('❌ Satış hatası: ' + error.message);
            return;
          }
        }
        
        alert('✅ Satış başarılı!');
        cart = [];
        document.getElementById('cartSection').style.display = 'none';
        document.getElementById('cartItems').innerHTML = '';
        document.getElementById('barcodeInput').value = '';
        loadRecentSales();
      };

      async function loadRecentSales() {
        try {
          const response = await fetch('/api/sales-history');
          const sales = await response.json();
          
          let html = '';
          sales.slice(0, 15).forEach(sale => {
            const sizeDisplay = sale.category === 'Çocuk Giyim' ? (sale.size + ' Yaş') : sale.size;
            const date = new Date(sale.createdAt).toLocaleString('tr-TR');
            html += `<div style="padding: 12px; border-bottom: 1px solid #eee;">
              <strong>${sale.productName}</strong><br>
              <small>${sizeDisplay} x${sale.quantity} | ${sale.price.toFixed(2)} TL | ${date}</small>
            </div>`;
          });
          
          document.getElementById('recentSales').innerHTML = html || '<p style="color: #999;">Henüz satış yok</p>';
        } catch (error) {
          console.error('Satış geçmişi yükleme hatası:', error);
        }
      }

      loadRecentSales();
      setInterval(loadRecentSales, 5000);
    </script>
  `
}) %>