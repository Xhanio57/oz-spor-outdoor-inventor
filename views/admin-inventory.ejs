<%- include('layout', { 
  title: 'Stok Listesi',
  body: `
    <div class="admin-panel">
      <div class="header">
        <h2>📊 Stok Listesi</h2>
        <button onclick="exportPDF()" class="btn btn-export">📄 PDF İndir</button>
        <button onclick="openBulkLabelModal()" class="btn btn-export">🏷️ Toplu Etiket</button>
      </div>

      <div id="productGrid" class="product-grid"></div>
    </div>

    <!-- Stok Güncelleme Modal -->
    <div id="stockModal" class="modal" style="display:none;">
      <div class="modal-content">
        <span class="close" onclick="closeStockModal()">&times;</span>
        <h3>📦 Stok Güncelle</h3>
        <div id="stockForm"></div>
      </div>
    </div>

    <!-- Toplu Etiket Modal -->
    <div id="bulkLabelModal" class="modal" style="display:none;">
      <div class="modal-content">
        <span class="close" onclick="closeBulkLabelModal()">&times;</span>
        <h3>🏷️ Toplu Etiket İndir</h3>
        <div id="labelOptions"></div>
      </div>
    </div>

    <script>
      const categoryLabels = {
        'Çocuk Giyim': (size) => `${size} Yaş`,
        'default': (size) => size
      };

      async function loadProducts() {
        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          
          let html = '';
          products.forEach(p => {
            const totalStock = p.sizeStock.reduce((a, b) => a + b.stock, 0);
            const formatter = categoryLabels[p.category] || categoryLabels['default'];
            const sizeDetails = p.sizeStock.map(s => `${formatter(s.size)}(${s.stock})`).join(', ');
            
            const stockColor = totalStock === 0 ? '#dc2626' : totalStock < 10 ? '#f59e0b' : '#10b981';
            
            html += `<div class="product-card">
              <img src="${p.image}" alt="${p.name}" style="width:100%;height:120px;object-fit:cover;border-radius:5px;">
              <h4>${p.name}</h4>
              <p><strong>Kategori:</strong> ${p.category}</p>
              <p><strong>Fiyat:</strong> ${p.price.toFixed(2)} TL</p>
              <p><strong>Barkod:</strong> ${p.barcode}</p>
              <p><strong>Stok:</strong> <span style="color:${stockColor};font-weight:bold;">${totalStock}</span></p>
              <p><strong>Bedenler:</strong> ${sizeDetails}</p>
              <div class="btn-group">
                <button onclick="openStockModal('${p._id}')" class="btn btn-small">📊 Stok Güncelle</button>
                <button onclick="editProduct('${p._id}')" class="btn btn-small">✏️ Düzenle</button>
                <button onclick="deleteProduct('${p._id}')" class="btn btn-small btn-danger">🗑️ Sil</button>
                <button onclick="labelPDF('${p._id}')" class="btn btn-small">🏷️ Etiket</button>
              </div>
            </div>`;
          });
          
          document.getElementById('productGrid').innerHTML = html;
        } catch (error) {
          console.error('Ürün yükleme hatası:', error);
        }
      }

      window.openStockModal = async (productId) => {
        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          const product = products.find(p => p._id === productId);
          const formatter = categoryLabels[product.category] || categoryLabels['default'];
          
          let html = '<form onsubmit="submitStockUpdate(event, \'' + productId + '\')"><table>';
          product.sizeStock.forEach(size => {
            const display = formatter(size.size);
            html += `<tr>
              <td>${display}</td>
              <td>Mevcut: ${size.stock}</td>
              <td><input type="number" id="stock_${size.size}" placeholder="Ekle/Çıkar" required></td>
            </tr>`;
          });
          html += '</table><button type="submit" class="btn btn-primary">✅ Güncelle</button></form>';
          
          document.getElementById('stockForm').innerHTML = html;
          document.getElementById('stockModal').style.display = 'block';
        } catch (error) {
          console.error('Modal açma hatası:', error);
        }
      };

      window.submitStockUpdate = async (e, productId) => {
        e.preventDefault();
        try {
          const response = await fetch('/api/products');
          const products = await response.json();
          const product = products.find(p => p._id === productId);
          
          for (let size of product.sizeStock) {
            const qty = document.getElementById('stock_' + size.size).value;
            if (qty) {
              await fetch(`/api/products/${productId}/size-stock`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ size: size.size, quantity: parseInt(qty) })
              });
            }
          }
          alert('✅ Stok güncellendi!');
          closeStockModal();
          loadProducts();
        } catch (error) {
          alert('Hata: ' + error.message);
        }
      };

      window.closeStockModal = () => {
        document.getElementById('stockModal').style.display = 'none';
      };

      window.openBulkLabelModal = () => {
        document.getElementById('bulkLabelModal').style.display = 'block';
      };

      window.closeBulkLabelModal = () => {
        document.getElementById('bulkLabelModal').style.display = 'none';
      };

      window.exportPDF = () => {
        window.open('/api/products/export/pdf/true', '_blank');
      };

      window.labelPDF = (productId) => {
        window.open(`/api/products/${productId}/label-pdf`, '_blank');
      };

      window.deleteProduct = async (productId) => {
        if (confirm('Ürünü silmek istediğinize emin misiniz?')) {
          try {
            const response = await fetch(`/api/products/${productId}`, { method: 'DELETE' });
            const result = await response.json();
            if (result.success) {
              alert('✅ Ürün silindi!');
              loadProducts();
            }
          } catch (error) {
            alert('Hata: ' + error.message);
          }
        }
      };

      loadProducts();
    </script>
  `
}) %>