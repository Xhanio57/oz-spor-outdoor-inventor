<%- include('layout', { 
    title: 'Stok Listesi',
    body: `<div class="admin-panel"><h2>Stok Listesi</h2><table class="inventory-table"><thead><tr><th>Resim</th><th>Ürün</th><th>Kategori</th><th>Barkod</th><th>Stok</th><th>Fiyat</th><th>İşlem</th></tr></thead><tbody id="tbody"></tbody></table></div><div id="m1" class="modal hidden"><div class="modal-content"><span class="close" onclick="document.getElementById('m1').classList.add('hidden')">&times;</span><h3>Stok Ekle</h3><input type="number" id="q" min="1"><button onclick="addS()" class="btn btn-primary">Ekle</button></div></div><div id="m2" class="modal hidden"><div class="modal-content"><span class="close" onclick="document.getElementById('m2').classList.add('hidden')">&times;</span><h3>Düzenle</h3><input type="text" id="n"><input type="number" id="pr" step="0.01"><select id="c"><option>Judo Ürünleri</option><option>Spor Giyim</option><option>Kamp Ekipmanları</option><option>Diğer</option></select><input type="number" id="s"><button onclick="editS()" class="btn btn-primary">Kaydet</button></div></div><div id="m3" class="modal hidden"><div class="modal-content"><span class="close" onclick="document.getElementById('m3').classList.add('hidden')">&times;</span><h3>Etiket</h3><input type="number" id="qty" min="1" max="100" value="6"><button onclick="labelS()" class="btn btn-primary">Yazdır</button></div></div><script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"><\/script><script>let prods=[],cid=null,cp=null;async function load(){const r=await fetch('/api/products');prods=await r.json();render()}function render(){const t=document.getElementById('tbody');t.innerHTML=prods.map(x=>'<tr><td><img src="'+x.image+'" style="width:50px;height:50px;object-fit:cover" onerror="this.src=\\'/images/default-product.svg\\'"><\/td><td>'+x.name+'<\/td><td>'+x.category+'<\/td><td>'+x.barcode+'<\/td><td>'+x.stock+'<\/td><td>'+x.price.toFixed(2)+' ₺<\/td><td><button onclick="os(\\' '+x._id+' \\')" class="btn btn-small">➕<\/button><button onclick="oe(\\' '+x._id+' \\')" class="btn btn-small">✏️<\/button><button onclick="ol(\\' '+x._id+' \\')" class="btn btn-small">🏷️<\/button><button onclick="del(\\' '+x._id+' \\')" class="btn btn-small btn-danger">🗑️<\/button><\/td><\/tr>').join('')}function os(id){cid=id;document.getElementById('m1').classList.remove('hidden')}async function addS(){const q=parseInt(document.getElementById('q').value);if(!q)return;await fetch('/api/products/'+cid+'/stock',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({quantity:q})});document.getElementById('m1').classList.add('hidden');load()}function oe(id){cid=id;const x=prods.find(z=>z._id===id);document.getElementById('n').value=x.name;document.getElementById('pr').value=x.price;document.getElementById('c').value=x.category;document.getElementById('s').value=x.stock;document.getElementById('m2').classList.remove('hidden')}async function editS(){await fetch('/api/products/'+cid,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:document.getElementById('n').value,price:parseFloat(document.getElementById('pr').value),category:document.getElementById('c').value,stock:parseInt(document.getElementById('s').value)})});document.getElementById('m2').classList.add('hidden');load()}function ol(id){cid=id;cp=prods.find(z=>z._id===id);document.getElementById('m3').classList.remove('hidden')}function labelS(){const q=parseInt(document.getElementById('qty').value);if(!q||q<1||q>100)return;const p=cp;let html='<!DOCTYPE html><html><head><meta charset=UTF-8><script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"><\/script><style>body{margin:5mm}div{display:grid;grid-template-columns:repeat(4,50mm);gap:5mm}.l{width:50mm;height:75mm;border:1px solid #ddd;padding:3mm;display:flex;flex-direction:column;gap:2mm}img{width:100%;height:25mm;object-fit:cover}h4{margin:0;font-size:10px}p{margin:0;font-size:8px}svg{width:100%;height:18mm}</style></head><body><div>';for(let i=0;i<q;i++){html+='<div class=l><img src="'+p.image+'" onerror="this.src=\\'/images/default-product.svg\\'"><h4>'+p.name.substring(0,15)+'<\/h4><p>'+p.category+'<\/p><p style=font-weight:bold>'+p.price.toFixed(2)+' ₺<\/p><svg id=b'+i+'><\/svg><p style=text-align:center>'+p.barcode+'<\/p><\/div>'}html+='<\/div><script>for(let i=0;i<'+q+';i++){JsBarcode("#b"+i,"'+p.barcode+'",{format:"CODE128",width:1,height:18});} setTimeout(()=>window.print(),500);<\/script><\/body><\/html>';const w=window.open();w.document.write(html);w.document.close();document.getElementById('m3').classList.add('hidden')}async function del(id){if(!confirm('Sil?'))return;await fetch('/api/products/'+id,{method:'DELETE'});load()}load()<\/script>` 
  }) %>