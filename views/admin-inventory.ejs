<%- include('layout', { 
  title: 'Stok Listesi',
  body: `<div class="admin-panel"><h2>Stok Listesi</h2><div class="filters"><input type="text" id="search" placeholder="Ürün adı veya barkod ara..."><select id="catFilter"><option value="">Tüm Kategoriler</option><option value="Spor Giyim">Spor Giyim</option><option value="Judogi">Judogi</option><option value="Kamp Malzemeleri">Kamp Malzemeleri</option><option value="Ayakkabı">Ayakkabı</option><option value="Aksesuarlar">Aksesuarlar</option><option value="Diğer">Diğer</option></select></div><table class="inventory-table"><thead><tr><th>Resim</th><th>Ürün</th><th>Kategori</th><th>Barkod</th><th>Stok</th><th>Fiyat</th><th>İşlem</th></tr></thead><tbody id="t"></tbody></table></div><div id="m1" class="modal hidden"><div class="modal-content"><span class="close" onclick="closeM('m1')">&times;</span><h3>📦 Stok Ekle</h3><div id="sizes" class="size-btns"></div><input type="number" id="q" min="1" placeholder="Miktar"><button onclick="addS()" class="btn btn-primary">Ekle</button></div></div><div id="m2" class="modal hidden"><div class="modal-content"><span class="close" onclick="closeM('m2')">&times;</span><h3>✏️ Düzenle</h3><input type="text" id="n"><input type="number" id="pr" step="0.01"><select id="c"><option value="Spor Giyim">Spor Giyim</option><option value="Judogi">Judogi</option><option value="Kamp Malzemeleri">Kamp Malzemeleri</option><option value="Ayakkabı">Ayakkabı</option><option value="Aksesuarlar">Aksesuarlar</option><option value="Diğer">Diğer</option></select><button onclick="editS()" class="btn btn-primary">Kaydet</button></div></div><div id="m3" class="modal hidden"><div class="modal-content"><span class="close" onclick="closeM('m3')">&times;</span><h3>🏷️ Etiket Yazdır</h3><input type="number" id="qty" min="1" max="100" value="1"><button onclick="labelS()" class="btn btn-primary">Yazdır</button></div></div><style>.admin-panel{background:white;padding:30px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1)}.filters{display:flex;gap:15px;margin-bottom:20px}.filters input,.filters select{padding:10px;border:1px solid #ddd;border-radius:6px;flex:1}.inventory-table{width:100%;border-collapse:collapse}.inventory-table th{background:#f5f5f5;padding:12px;text-align:left;border-bottom:2px solid #ddd}.inventory-table td{padding:12px;border-bottom:1px solid #eee}.inventory-table img{width:50px;height:50px;object-fit:cover;border-radius:4px}.size-btns{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:15px}.size-btn{padding:8px;border:2px solid #ddd;background:white;border-radius:4px;cursor:pointer;font-weight:500}.size-btn.active{background:#2563eb;color:white;border-color:#2563eb}.modal{display:none;position:fixed;z-index:1000;left:0;top:0;width:100%;height:100%;background:rgba(0,0,0,0.4)}.modal:not(.hidden){display:flex}.modal-content{background:white;margin:auto;padding:30px;border-radius:8px;width:90%;max-width:500px;box-shadow:0 4px 6px rgba(0,0,0,0.1)}.modal-content h3{margin-bottom:20px}.close{float:right;font-size:28px;font-weight:bold;color:#999;cursor:pointer}.close:hover{color:#333}.modal-content input,.modal-content select{width:100%;padding:10px;margin-bottom:15px;border:1px solid #ddd;border-radius:4px;box-sizing:border-box}.btn{padding:8px 12px;border:none;border-radius:4px;cursor:pointer;font-weight:500}.btn-primary{background:#2563eb;color:white}.btn-small{font-size:12px;padding:6px 10px;margin:0 2px}.btn-danger{background:#dc2626;color:white}</style><script>let prods=[],cid=null,cp=null,cs=null;async function load(){const r=await fetch('/api/products');prods=await r.json();render()}function render(){const t=document.getElementById('t');const s=document.getElementById('search').value.toLowerCase();const cf=document.getElementById('catFilter').value;let f=prods.filter(p=>(p.name.toLowerCase().includes(s)||p.barcode.includes(s))&&(!cf||p.category===cf));t.innerHTML=f.map(p=>{const tot=p.sizeStock.reduce((a,b)=>a+b.stock,0);return '<tr><td><img src="'+p.image+'" onerror="this.src=\\'/images/default-product.svg\\'"><\/td><td>'+p.name+'<\/td><td>'+p.category+'<\/td><td><code>'+p.barcode+'<\/code><\/td><td>'+tot+'<\/td><td>'+p.price.toFixed(2)+' ₺<\/td><td><button onclick="os(\\''+p._id+'\\')" class="btn btn-small">➕<\/button><button onclick="oe(\\''+p._id+'\\')" class="btn btn-small">✏️<\/button><button onclick="ol(\\''+p._id+'\\')" class="btn btn-small">🏷️<\/button><button onclick="del(\\''+p._id+'\\')" class="btn btn-small btn-danger">🗑️<\/button><\/td><\/tr>'}).join('')}function os(id){cid=id;cp=prods.find(p=>p._id===id);const sb=document.getElementById('sizes');sb.innerHTML=cp.sizeStock.map(s=>'<button type="button" class="size-btn" onclick="selectSize(\\''+s.size+'\\'\\')">'+s.size+'<\/button>').join('');document.getElementById('m1').classList.remove('hidden')}function selectSize(s){cs=s;document.querySelectorAll('.size-btn').forEach(b=>b.classList.toggle('active',b.textContent===s))}async function addS(){if(!cs){alert('Beden seç');return}const q=parseInt(document.getElementById('q').value);if(!q)return;await fetch('/api/products/'+cid+'/size-stock',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({size:cs,quantity:q})});closeM('m1');load()}function oe(id){cid=id;const x=prods.find(z=>z._id===id);document.getElementById('n').value=x.name;document.getElementById('pr').value=x.price;document.getElementById('c').value=x.category;document.getElementById('m2').classList.remove('hidden')}async function editS(){await fetch('/api/products/'+cid,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:document.getElementById('n').value,price:parseFloat(document.getElementById('pr').value),category:document.getElementById('c').value})});closeM('m2');load()}function ol(id){cid=id;cp=prods.find(z=>z._id===id);document.getElementById('m3').classList.remove('hidden')}function labelS(){const q=parseInt(document.getElementById('qty').value);if(!q||q<1||q>100)return;window.open('/api/products/'+cid+'/label-pdf');closeM('m3')}async function del(id){if(!confirm('Sil?'))return;await fetch('/api/products/'+id,{method:'DELETE'});load()}function closeM(id){document.getElementById(id).classList.add('hidden')}document.getElementById('search').addEventListener('keyup',render);document.getElementById('catFilter').addEventListener('change',render);load()<\/script>` 
}) %>
