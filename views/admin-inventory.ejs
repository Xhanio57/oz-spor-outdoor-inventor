<%- include('layout', { 
  title: 'Stok Listesi',
  body: `
    <div class="admin-panel">
      <h2>📊 Stok Yönetimi</h2>
      
      <div class="filters">
        <input type="text" id="searchInput" placeholder="Ürün adı veya barkod ara..." class="search-input">
        <select id="categoryFilter" class="filter-select">
          <option value="">Tümü</option>
          <option value="Judo Ürünleri">Judo Ürünleri</option>
          <option value="Spor Giyim">Spor Giyim</option>
          <option value="Kamp Ekipmanları">Kamp Ekipmanları</option>
          <option value="Diğer">Diğer</option>
        </select>
      </div>

      <table class="inventory-table">
        <thead>
          <tr>
            <th>Resim</th>
            <th>Ürün Adı</th>
            <th>Kategori</th>
            <th>Barkod</th>
            <th>Fiyat</th>
            <th>Beden Stokları</th>
            <th>Toplam</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>

    <!-- Modal: Beden Stok Ekle -->
    <div id="m1" class="modal hidden">
      <div class="modal-content">
        <span class="close" onclick="closeModal('m1')">&times;</span>
        <h3>📦 Stok Ekle</h3>
        <div id="sizeButtons" class="size-buttons"></div>
        <div class="stock-input-group">
          <input type="number" id="quantityInput" min="1" placeholder="Miktar" class="input-field">
          <button onclick="addStock()" class="btn btn-primary">Ekle</button>
        </div>
      </div>
    </div>

    <!-- Modal: Ürün Düzenle -->
    <div id="m2" class="modal hidden">
      <div class="modal-content">
        <span class="close" onclick="closeModal('m2')">&times;</span>
        <h3>✏️ Ürün Düzenle</h3>
        <input type="text" id="editName" placeholder="Ürün Adı" class="input-field">
        <input type="number" id="editPrice" step="0.01" placeholder="Fiyat" class="input-field">
        <select id="editCategory" class="input-field">
          <option value="Judo Ürünleri">Judo Ürünleri</option>
          <option value="Spor Giyim">Spor Giyim</option>
          <option value="Kamp Ekipmanları">Kamp Ekipmanları</option>
          <option value="Diğer">Diğer</option>
        </select>
        <button onclick="updateProduct()" class="btn btn-primary">Kaydet</button>
      </div>
    </div>

    <!-- Modal: Etiket Yazdır -->
    <div id="m3" class="modal hidden">
      <div class="modal-content">
        <span class="close" onclick="closeModal('m3')">&times;</span>
        <h3>🏷️ Etiket Yazdır</h3>
        <input type="number" id="labelQty" min="1" max="100" value="1" placeholder="Kaç adet?" class="input-field">
        <button onclick="printLabel()" class="btn btn-primary">Yazdır</button>
      </div>
    </div>

    <style>
      .admin-panel {
        background: white;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      }

      .admin-panel h2 {
        margin-bottom: 20px;
        color: #333;
        font-size: 24px;
      }

      .filters {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
      }

      .search-input, .filter-select {
        padding: 10px 15px;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: 14px;
        flex: 1;
      }

      .inventory-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
      }

      .inventory-table thead {
        background: #f5f5f5;
        border-bottom: 2px solid #ddd;
      }

      .inventory-table th {
        padding: 12px;
        text-align: left;
        font-weight: 600;
        color: #333;
      }

      .inventory-table td {
        padding: 12px;
        border-bottom: 1px solid #eee;
      }

      .inventory-table img {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 4px;
      }

      .size-stock-display {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .size-badge {
        background: #f0f0f0;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
      }

      .size-badge.low {
        background: #fef3c7;
        color: #b45309;
      }

      .size-badge.out {
        background: #fee2e2;
        color: #dc2626;
      }

      .total-stock {
        font-weight: bold;
        color: #2563eb;
      }

      .btn {
        padding: 8px 12px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.3s ease;
      }

      .btn-primary {
        background: #2563eb;
        color: white;
      }

      .btn-primary:hover {
        background: #1d4ed8;
      }

      .btn-small {
        padding: 6px 10px;
        font-size: 12px;
        margin: 0 2px;
      }

      .btn-danger {
        background: #dc2626;
        color: white;
      }

      .btn-danger:hover {
        background: #b91c1c;
      }

      .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.4);
      }

      .modal.hidden {
        display: none;
      }

      .modal:not(.hidden) {
        display: flex;
      }

      .modal-content {
        background-color: white;
        margin: auto;
        padding: 30px;
        border-radius: 8px;
        width: 90%;
        max-width: 500px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      }

      .modal-content h3 {
        margin-bottom: 20px;
        color: #333;
      }

      .close {
        float: right;
        font-size: 28px;
        font-weight: bold;
        color: #999;
        cursor: pointer;
      }

      .close:hover {
        color: #333;
      }

      .input-field {
        width: 100%;
        padding: 10px;
        margin-bottom: 15px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 14px;
        box-sizing: border-box;
      }

      .size-buttons {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 20px;
      }

      .size-btn {
        padding: 10px;
        border: 2px solid #ddd;
        background: white;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.3s ease;
      }

      .size-btn:hover {
        border-color: #2563eb;
        color: #2563eb;
      }

      .size-btn.active {
        background: #2563eb;
        color: white;
        border-color: #2563eb;
      }

      .stock-input-group {
        display: flex;
        gap: 10px;
      }

      .stock-input-group input {
        flex: 1;
      }

      .stock-input-group button {
        flex: 0 0 auto;
        width: 100px;
      }

      .action-buttons {
        display: flex;
        gap: 5px;
      }
    </style>

    <script>
      let products = [];
      let currentProduct = null;
      let selectedSize = null;

      async function loadProducts() {
        try {
          const response = await fetch('/api/products');
          if (!response.ok) throw new Error('Ürünler yüklenemedi');
          products = await response.json();
          renderTable();
        } catch (error) {
          console.error('Hata:', error);
          alert('Ürünler yüklenemedi: ' + error.message);
        }
      }

      function renderTable() {
        const tbody = document.getElementById('tbody');
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const categoryFilter = document.getElementById('categoryFilter').value;

        let filtered = products.filter(p => {
          const matchesSearch = p.name.toLowerCase().includes(searchTerm) || 
                               p.barcode.includes(searchTerm);
          const matchesCategory = !categoryFilter || p.category === categoryFilter;
          return matchesSearch && matchesCategory;
        });

        tbody.innerHTML = filtered.map(p => {
          const totalStock = p.sizeStock.reduce((sum, s) => sum + s.stock, 0);
          const sizeDisplay = p.sizeStock.map(s => {
            let badgeClass = 'size-badge';
            if (s.stock === 0) badgeClass += ' out';
            else if (s.stock < 5) badgeClass += ' low';
            return '<span class="' + badgeClass + '">' + s.size + ': ' + s.stock + '</span>';
          }).join('');

          return '<tr>' +
            '<td><img src="' + (p.image || '/images/default-product.png') + '" onerror="this.src=\\'/images/default-product.svg\\'"></td>' +
            '<td>' + p.name + '</td>' +
            '<td>' + p.category + '</td>' +
            '<td><code>' + p.barcode + '</code></td>' +
            '<td>' + p.price.toFixed(2) + ' ₺</td>' +
            '<td><div class="size-stock-display">' + sizeDisplay + '</div></td>' +
            '<td><span class="total-stock">' + totalStock + '</span></td>' +
            '<td><div class="action-buttons">' +
              '<button onclick="openStockModal(\\'' + p._id + '\\')" class="btn btn-small">📦</button>' +
              '<button onclick="openEditModal(\\'' + p._id + '\\')" class="btn btn-small">✏️</button>' +
              '<button onclick="openLabelModal(\\'' + p._id + '\\')" class="btn btn-small">🏷️</button>' +
              '<button onclick="deleteProduct(\\'' + p._id + '\\')" class="btn btn-small btn-danger">🗑️</button>' +
            '</div></td>' +
            '</tr>';
        }).join('');
      }

      function openStockModal(productId) {
        currentProduct = products.find(p => p._id === productId);
        selectedSize = null;

        const sizeButtonsDiv = document.getElementById('sizeButtons');
        sizeButtonsDiv.innerHTML = currentProduct.sizeStock.map(s =>
          '<button type="button" class="size-btn" onclick="selectSize(\\'' + s.size + '\\')">' + s.size + '</button>'
        ).join('');

        document.getElementById('m1').classList.remove('hidden');
      }

      function selectSize(size) {
        selectedSize = size;
        document.querySelectorAll('.size-btn').forEach(btn => {
          btn.classList.toggle('active', btn.textContent === size);
        });
      }

      async function addStock() {
        if (!selectedSize) {
          alert('Lütfen bir beden seçin');
          return;
        }

        const quantity = parseInt(document.getElementById('quantityInput').value);
        if (!quantity || quantity < 1) {
          alert('Geçerli bir miktar girin');
          return;
        }

        try {
          const response = await fetch('/api/products/' + currentProduct._id + '/size-stock', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ size: selectedSize, quantity: quantity })
          });

          if (!response.ok) throw new Error('Stok eklenemedi');

          document.getElementById('m1').classList.add('hidden');
          document.getElementById('quantityInput').value = '';
          loadProducts();
        } catch (error) {
          alert('Hata: ' + error.message);
        }
      }

      function openEditModal(productId) {
        currentProduct = products.find(p => p._id === productId);
        document.getElementById('editName').value = currentProduct.name;
        document.getElementById('editPrice').value = currentProduct.price;
        document.getElementById('editCategory').value = currentProduct.category;
        document.getElementById('m2').classList.remove('hidden');
      }

      async function updateProduct() {
        try {
          const response = await fetch('/api/products/' + currentProduct._id, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: document.getElementById('editName').value,
              price: parseFloat(document.getElementById('editPrice').value),
              category: document.getElementById('editCategory').value
            })
          });

          if (!response.ok) throw new Error('Güncelleme başarısız');

          document.getElementById('m2').classList.add('hidden');
          loadProducts();
        } catch (error) {
          alert('Hata: ' + error.message);
        }
      }

      function openLabelModal(productId) {
        currentProduct = products.find(p => p._id === productId);
        document.getElementById('m3').classList.remove('hidden');
      }

      async function printLabel() {
        const quantity = parseInt(document.getElementById('labelQty').value);
        if (!quantity || quantity < 1) {
          alert('Geçerli bir miktar girin');
          return;
        }

        window.open('/api/products/' + currentProduct._id + '/label-pdf');
        document.getElementById('m3').classList.add('hidden');
      }

      async function deleteProduct(productId) {
        if (!confirm('Bu ürünü silmek istediğinize emin misiniz?')) return;

        try {
          const response = await fetch('/api/products/' + productId, {
            method: 'DELETE'
          });

          if (!response.ok) throw new Error('Silme başarısız');

          loadProducts();
        } catch (error) {
          alert('Hata: ' + error.message);
        }
      }

      function closeModal(modalId) {
        document.getElementById(modalId).classList.add('hidden');
      }

      // Event listeners
      document.getElementById('searchInput').addEventListener('keyup', renderTable);
      document.getElementById('categoryFilter').addEventListener('change', renderTable);

      // Başlat
      loadProducts();
    <\/script>
  ` 
}) %>