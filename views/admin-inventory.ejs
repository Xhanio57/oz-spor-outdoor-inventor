ton><button onclick="oe(\\''+p._id+'\\')" class="btn btn-small">✏️<\/button><button onclick="ol(\\''+p._id+'\\')" class="btn btn-small">🏷️<\/button><button onclick="del(\\''+p._id+'\\')" class="btn btn-small btn-danger">🗑️<\/button><\/div><\/td><\/tr>'}).join('')}function os(id){cid=id;cp=prods.find(p=>p._id===id);cs=null;const sb=document.getElementById('sizes');sb.innerHTML=cp.sizeStock.map(s=>'<button type="button" class="size-btn" onclick="selectSize(\\''+s.size+'\\')" data-size="'+s.size+'">'+s.size+'<\/button>').join('');document.getElementById('m1').classList.remove('hidden')}function selectSize(s){cs=s;document.querySelectorAll('.size-btn').forEach(b=>{if(b.getAttribute('data-size')===s){b.classList.add('active')}else{b.classList.remove('active')}})}async function addS(){if(!cs){alert('Lütfen bir beden seçin');return}const q=parseInt(document.getElementById('q').value);if(!q||q<1){alert('Geçerli bir miktar girin');return}try{const response=await fetch('/api/products/'+cid+'/size-stock',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({size:cs,quantity:q})});if(!response.ok)throw new Error('Stok eklenemedi');document.getElementById('q').value='';closeM('m1');load()}catch(error){alert('Hata: '+error.message)}}function oe(id){cid=id;const x=prods.find(z=>z._id===id);document.getElementById('n').value=x.name;document.getElementById('pr').value=x.price;document.getElementById('c').value=x.category;document.getElementById('m2').classList.remove('hidden')}async function editS(){try{const response=await fetch('/api/products/'+cid,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:document.getElementById('n').value,price:parseFloat(document.getElementById('pr').value),category:document.getElementById('c').value})});if(!response.ok)throw new Error('Güncelleme başarısız');closeM('m2');load()}catch(error){alert('Hata: '+error.message)}}function ol(id){cid=id;cp=prods.find(z=>z._id===id);document.getElementById('m3').classList.remove('hidden')}function labelS(){const q=parseInt(document.getElementById('qty').value);if(!q||q<1||q>100){alert('Geçerli bir miktar girin (1-100)');return}window.open('/api/products/'+cid+'/label-pdf');closeM('m3')}async function del(id){if(!confirm('Bu ürünü silmek istediğinize emin misiniz?'))return;try{const response=await fetch('/api/products/'+id,{method:'DELETE'});if(!response.ok)throw new Error('Silme başarısız');load()}catch(error){alert('Hata: '+error.message)}}function exportPDF(){document.getElementById('m4').classList.remove('hidden')}function generatePDF(){const includeStock=document.getElementById('chkStock').checked;const url='/api/products/export/pdf/'+includeStock;window.location.href=url;closeM('m4')}function closeM(id){document.getElementById(id).classList.add('hidden')}document.getElementById('search').addEventListener('keyup',render);document.getElementById('catFilter').addEventListener('change',render);load()<\/script>` 
