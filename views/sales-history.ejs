<%- include('layout', { 
  title: 'Satış Geçmişi',
  body: `
    <div class="sales-history-container">
      <h2>📋 Satış Geçmişi</h2>
      
      <div class="filter-section">
        <input type="date" id="startDate">
        <input type="date" id="endDate">
        <button onclick="filterByDate()" class="btn btn-primary">🔍 Filtrele</button>
        <button onclick="loadSalesHistory()" class="btn">↻ Tümü</button>
      </div>

      <table class="sales-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Ürün Adı</th>
            <th>Kategori</th>
            <th>Beden/Yaş</th>
            <th>Miktar</th>
            <th>Birim Fiyat</th>
            <th>Toplam</th>
            <th>Ödeme Şekli</th>
            <th>Tarih</th>
            <th>İşlem</th>
          </tr>
        </thead>
        <tbody id="salesBody"></tbody>
      </table>
    </div>

    <script>
      const escapeHtml = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

      const categoryLabels = {
        'Çocuk Giyim': (size) => size + ' Yaş',
        'default': (size) => size
      };

      const bindDeleteButtons = () => {
        document.querySelectorAll('.delete-sale-btn').forEach((button) => {
          button.addEventListener('click', () => {
            window.deleteSale(button.dataset.saleId);
          });
        });
      };

      async function loadSalesHistory() {
        try {
          const response = await fetch('/api/sales-history');
          const sales = await response.json();
          
          let html = '';
          sales.forEach((sale, idx) => {
            const formatter = categoryLabels[sale.category] || categoryLabels['default'];
            const sizeDisplay = formatter(sale.size);
            const totalPrice = (sale.price * sale.quantity).toFixed(2);
            const date = new Date(sale.createdAt).toLocaleString('tr-TR');
            const saleId = escapeHtml(sale._id);
            const productName = escapeHtml(sale.productName);
            const category = escapeHtml(sale.category || 'N/A');
            const safeSizeDisplay = escapeHtml(sizeDisplay);
            const paymentMethod = escapeHtml(sale.paymentMethod);
            const safeDate = escapeHtml(date);
            
            html += '<tr>' +
              '<td>' + (idx + 1) + '</td>' +
              '<td>' + productName + '</td>' +
              '<td>' + category + '</td>' +
              '<td>' + safeSizeDisplay + '</td>' +
              '<td>' + sale.quantity + '</td>' +
              '<td>' + sale.price.toFixed(2) + ' TL</td>' +
              '<td>' + totalPrice + ' TL</td>' +
              '<td>' + paymentMethod + '</td>' +
              '<td>' + safeDate + '</td>' +
              '<td><button class="btn btn-small btn-danger delete-sale-btn" data-sale-id="' + saleId + '">Geri Al</button></td>' +
            '</tr>';
          });
          
          document.getElementById('salesBody').innerHTML = html;
          bindDeleteButtons();
        } catch (error) {
          console.error('Satış geçmişi yükleme hatası:', error);
        }
      }

      window.filterByDate = async () => {
        const start = document.getElementById('startDate').value;
        const end = document.getElementById('endDate').value;
        
        if (!start || !end) {
          alert('Lütfen başlangıç ve bitiş tarihleri seçin!');
          return;
        }
        
        try {
          const response = await fetch('/api/sales-history/date/' + start + '/' + end);
          const sales = await response.json();
          
          let html = '';
          sales.forEach((sale, idx) => {
            const formatter = categoryLabels[sale.category] || categoryLabels['default'];
            const sizeDisplay = formatter(sale.size);
            const totalPrice = (sale.price * sale.quantity).toFixed(2);
            const date = new Date(sale.createdAt).toLocaleString('tr-TR');
            const saleId = escapeHtml(sale._id);
            const productName = escapeHtml(sale.productName);
            const category = escapeHtml(sale.category || 'N/A');
            const safeSizeDisplay = escapeHtml(sizeDisplay);
            const paymentMethod = escapeHtml(sale.paymentMethod);
            const safeDate = escapeHtml(date);
            
            html += '<tr>' +
              '<td>' + (idx + 1) + '</td>' +
              '<td>' + productName + '</td>' +
              '<td>' + category + '</td>' +
              '<td>' + safeSizeDisplay + '</td>' +
              '<td>' + sale.quantity + '</td>' +
              '<td>' + sale.price.toFixed(2) + ' TL</td>' +
              '<td>' + totalPrice + ' TL</td>' +
              '<td>' + paymentMethod + '</td>' +
              '<td>' + safeDate + '</td>' +
              '<td><button class="btn btn-small btn-danger delete-sale-btn" data-sale-id="' + saleId + '">Geri Al</button></td>' +
            '</tr>';
          });
          
          document.getElementById('salesBody').innerHTML = html;
          bindDeleteButtons();
        } catch (error) {
          alert('Hata: ' + error.message);
        }
      };

      window.deleteSale = async (saleId) => {
        if (confirm('Satışı iptal etmek istediğinize emin misiniz?')) {
          try {
            const response = await fetch('/api/sales-history/' + saleId + '?restore=true', { method: 'DELETE' });
            const result = await response.json();
            if (result.success) {
              alert('✅ ' + result.message);
              loadSalesHistory();
            }
          } catch (error) {
            alert('Hata: ' + error.message);
          }
        }
      };

      loadSalesHistory();
    </script>
  `
}) %>
