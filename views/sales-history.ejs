<%- include('layout', { 
  title: 'Satış Geçmişi',
  body: `<div class="history-container"><h2>📊 Satış Geçmişi</h2><div class="filters"><input type="date" id="startDate" class="inp"><input type="date" id="endDate" class="inp"><button onclick="filterByDate()" class="btn btn-primary">Filtrele</button><button onclick="loadAllHistory()" class="btn btn-secondary">Tümü Göster</button></div><table class="history-table"><thead><tr><th>Tarih/Saat</th><th>Ürün</th><th>Beden</th><th>Adet</th><th>Birim Fiyat</th><th>Total</th><th>Ödeme</th><th>Kasiyeri</th><th>İşlem</th></tr></thead><tbody id="hist"></tbody></table><div class="summary"><div class="card"><h4>Toplam Satış</h4><p id="totalSales">0</p></div><div class="card"><h4>Toplam Gelir</h4><p id="totalRevenue">0.00 ₺</p></div><div class="card"><h4>Toplam Adet</h4><p id="totalQty">0</p></div></div></div><div id="deleteModal" class="modal hidden"><div class="modal-content"><span class="close" onclick="closeModal()">&times;</span><h3>⚠️ Satışı Sil</h3><p id="deleteMsg" style="margin-bottom:20px;color:#333"></p><label style="display:block;margin-bottom:15px;cursor:pointer;font-size:14px"><input type="checkbox" id="restoreStock"> Ürün stoğu yeniden eklensin mi?</label><div style="display:flex;gap:10px"><button onclick="confirmDelete()" class="btn btn-danger" style="flex:1">Sil</button><button onclick="closeModal()" class="btn btn-secondary" style="flex:1">İptal</button></div></div></div><style>.history-container{background:white;padding:30px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1)}.history-container h2{margin-bottom:20px;color:#333}.filters{display:flex;gap:10px;margin-bottom:25px}.filters input{padding:10px;border:1px solid #ddd;border-radius:6px;flex:1}.filters .btn{flex:0 0 auto;padding:10px 20px}.history-table{width:100%;border-collapse:collapse;margin-bottom:30px}.history-table th{background:#f5f5f5;padding:12px;text-align:left;border-bottom:2px solid #ddd;font-weight:600}.history-table td{padding:10px;border-bottom:1px solid #eee;font-size:13px}.history-table tr:hover{background:#f9f9f9}.history-table .del-btn{background:#dc2626;color:white;border:0;padding:6px 10px;border-radius:4px;cursor:pointer;font-size:11px;font-weight:500}.history-table .del-btn:hover{background:#b91c1c}.summary{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:30px}.card{background:#f5f5f5;padding:20px;border-radius:8px;text-align:center}.card h4{color:#666;font-size:12px;margin-bottom:10px;text-transform:uppercase}.card p{font-size:24px;font-weight:bold;color:#2563eb}.inp{width:100%;padding:10px;border:1px solid #ddd;border-radius:6px;box-sizing:border-box}.btn{border:none;border-radius:6px;cursor:pointer;font-weight:500;padding:10px 15px}.btn-primary{background:#2563eb;color:white}.btn-primary:hover{background:#1d4ed8}.btn-secondary{background:#6b7280;color:white}.btn-secondary:hover{background:#4b5563}.btn-danger{background:#dc2626;color:white}.btn-danger:hover{background:#b91c1c}.modal{display:none;position:fixed;z-index:1000;left:0;top:0;width:100%;height:100%;background:rgba(0,0,0,0.4)}.modal:not(.hidden){display:flex;align-items:center;justify-content:center}.modal-content{background:white;padding:30px;border-radius:8px;width:90%;max-width:400px;box-shadow:0 4px 6px rgba(0,0,0,0.1)}.modal-content h3{margin-bottom:15px}.close{float:right;font-size:28px;font-weight:bold;color:#999;cursor:pointer;line-height:1}.close:hover{color:#333}</style><script>let allHistory=[];let selectedSaleId=null;async function loadAllHistory(){try{const r=await fetch('/api/sales-history');allHistory=await r.json();render()}catch(e){alert('Hata: '+e.message)}}function render(){const h=document.getElementById('hist');h.innerHTML=allHistory.map(s=>{const d=new Date(s.createdAt);const dt=d.toLocaleDateString('tr-TR')+' '+d.toLocaleTimeString('tr-TR');return '<tr><td>'+dt+'<\/td><td>'+s.productName+'<\/td><td>'+s.size+'<\/td><td>'+s.quantity+'<\/td><td>'+s.price.toFixed(2)+' ₺<\/td><td><strong>'+s.totalPrice.toFixed(2)+' ₺<\/strong><\/td><td>'+s.paymentMethod+'<\/td><td>'+s.cashier+'<\/td><td><button class="del-btn" onclick="openDeleteModal(\\''+s._id+'\\',\\''+s.productName+'\\',\\''+s.size+'\\','+s.quantity+')">Sil<\/button><\/td><\/tr>'}).join('');updateSummary()}function updateSummary(){const ts=allHistory.length;const tr=allHistory.reduce((a,s)=>a+s.totalPrice,0);const tq=allHistory.reduce((a,s)=>a+s.quantity,0);document.getElementById('totalSales').textContent=ts;document.getElementById('totalRevenue').textContent=tr.toFixed(2)+' ₺';document.getElementById('totalQty').textContent=tq}async function filterByDate(){const sd=document.getElementById('startDate').value;const ed=document.getElementById('endDate').value;if(!sd||!ed){alert('Başlangıç ve bitiş tarihi seçin');return}try{const r=await fetch('/api/sales-history/date/'+sd+'/'+ed);allHistory=await r.json();render()}catch(e){alert('Hata: '+e.message)}}function openDeleteModal(id,name,size,qty){selectedSaleId=id;document.getElementById('deleteMsg').innerHTML='<strong>'+name+'<\/strong> (Beden: '+size+', Adet: '+qty+') satışı silinecektir.';document.getElementById('restoreStock').checked=true;document.getElementById('deleteModal').classList.remove('hidden')}async function confirmDelete(){const restoreStock=document.getElementById('restoreStock').checked;try{const res=await fetch('/api/sales-history/'+selectedSaleId+'?restore='+restoreStock,{method:'DELETE'});if(!res.ok){const err=await res.json();alert('Hata: '+err.message);return}alert('✅ Satış silindi');closeModal();loadAllHistory()}catch(e){alert('Hata: '+e.message)}}function closeModal(){document.getElementById('deleteModal').classList.add('hidden');selectedSaleId=null}loadAllHistory()<\/script>` 
}) %>
