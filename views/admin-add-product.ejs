<%- include('layout', { 
  title: 'Ürün Ekle',
  body: `
    <div class="admin-panel">
      <h2>📦 Yeni Ürün Ekle</h2>
      
      <div id="notification" class="notification hidden"></div>

      <form id="addProductForm" class="form">
        <div class="form-group">
          <label for="productName">Ürün Adı *</label>
          <input 
            type="text" 
            id="productName" 
            name="name" 
            placeholder="Örn: Judo Kimono Beyaz" 
            required
          >
        </div>

        <div class="form-group">
          <label for="productPrice">Fiyat (₺) *</label>
          <input 
            type="number" 
            id="productPrice" 
            name="price" 
            placeholder="Örn: 899.99" 
            step="0.01"
            min="0"
            required
          >
        </div>

        <div class="form-group">
          <label for="productCategory">Kategori *</label>
          <select id="productCategory" name="category" required>
            <option value="">-- Kategori Seçin --</option>
            <option value="Judogi">Judogi</option>
            <option value="Ayakkabı">Ayakkabı</option>
            <option value="Spor Giyim">Spor Giyim</option>
            <option value="Kamp Malzemeleri">Kamp Malzemeleri</option>
            <option value="Aksesuarlar">Aksesuarlar</option>
            <option value="Diğer">Diğer</option>
          </select>
        </div>

        <div class="form-group" id="sizeGroup" style="display:none;">
          <label for="productSize">Beden *</label>
          <select id="productSize" name="size"></select>
        </div>

        <div class="form-group">
          <label for="productStock">Başlangıç Stoku</label>
          <input 
            type="number" 
            id="productStock" 
            name="stock" 
            placeholder="Örn: 50" 
            min="0"
            value="0"
          >
        </div>

        <div class="form-group">
          <label for="productImage">Ürün Resmi (URL)</label>
          <input 
            type="url" 
            id="productImage" 
            name="image" 
            placeholder="https://example.com/urun.jpg"
          >
          <small>Resim URL'si. Boş bırakılırsa placeholder kullanılır.</small>
        </div>

        <div class="form-group">
          <label for="productDescription">Ürün Açıklaması</label>
          <textarea 
            id="productDescription" 
            name="description" 
            placeholder="Ürün hakkında bilgi..."
            rows="3"
          ></textarea>
        </div>

        <div class="form-group">
          <label for="productBarcode">Barkod (İsteğe Bağlı)</label>
          <input 
            type="text" 
            id="productBarcode" 
            name="barcode" 
            placeholder="Otomatik üretilirse boş bırakın"
          >
          <small>Boş bırakılırsa otomatik 8 haneli barkod üretilecektir.</small>
        </div>

        <button type="submit" class="btn btn-primary">✓ Ürünü Ekle</button>
      </form>
    </div>

    <script>
      const form = document.getElementById('addProductForm');
      const notification = document.getElementById('notification');
      const categorySelect = document.getElementById('productCategory');
      const sizeGroup = document.getElementById('sizeGroup');
      const sizeSelect = document.getElementById('productSize');
      let isSizeSelectionRequired = false;

      function resetSizeSelect() {
        sizeSelect.innerHTML = '<option value="">-- Beden Seçin --</option>';
      }

      categorySelect.addEventListener('change', async (e) => {
        const category = e.target.value;
        resetSizeSelect();

        if (!category) {
          isSizeSelectionRequired = false;
          sizeGroup.style.display = 'none';
          return;
        }

        try {
          const response = await fetch(`/api/sizes/${encodeURIComponent(category)}`);
          const data = await response.json();

          if (!response.ok || !data.success) {
            throw new Error(data.message || 'Bedenler yüklenemedi');
          }

          const onlyStandard = data.sizes.length === 1 && data.sizes[0] === 'Standart';
          if (onlyStandard) {
            isSizeSelectionRequired = false;
            sizeGroup.style.display = 'none';
            return;
          }

          data.sizes.forEach((size) => {
            const option = document.createElement('option');
            option.value = size;
            option.textContent = size;
            sizeSelect.appendChild(option);
          });
          isSizeSelectionRequired = true;
          sizeGroup.style.display = 'block';
        } catch (error) {
          isSizeSelectionRequired = false;
          sizeGroup.style.display = 'none';
          showNotification(error.message, 'error');
        }
      });

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        if (isSizeSelectionRequired && !sizeSelect.value) {
          showNotification('Lütfen beden seçin', 'error');
          return;
        }

        const formData = {
          name: document.getElementById('productName').value,
          price: parseFloat(document.getElementById('productPrice').value),
          category: document.getElementById('productCategory').value,
          size: isSizeSelectionRequired ? sizeSelect.value : 'Standart',
          stock: parseInt(document.getElementById('productStock').value) || 0,
          image: document.getElementById('productImage').value.trim() || undefined,
          description: document.getElementById('productDescription').value.trim() || '',
          barcode: document.getElementById('productBarcode').value.trim() || null
        };

        try {
          const response = await fetch('/api/products', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });

          const data = await response.json();

          if (data.success) {
            showNotification(data.message, 'success');
            form.reset();
            resetSizeSelect();
            isSizeSelectionRequired = false;
            sizeGroup.style.display = 'none';
          } else {
            showNotification(data.message, 'error');
          }
        } catch (error) {
          showNotification('Hata: ' + error.message, 'error');
        }
      });

      function showNotification(message, type) {
        notification.textContent = message;
        notification.className = 'notification ' + type;
        notification.classList.remove('hidden');
        
        setTimeout(() => {
          notification.classList.add('hidden');
        }, 5000);
      }
    </script>
  ` 
}) %>
