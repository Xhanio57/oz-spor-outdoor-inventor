<%- include('layout', { 
  title: 'Ürün Ekle',
  body: `<div class="form-container"><h2>➕ Yeni Ürün Ekle</h2><form id="productForm"><input type="text" id="name" placeholder="Ürün Adı" required><input type="number" id="price" step="0.01" placeholder="Fiyat" required><select id="category" required onchange="updateSizeOptions()"><option value="">Kategori Seç</option><option value="Spor Giyim">Spor Giyim</option><option value="Judogi">Judogi</option><option value="Kamp Malzemeleri">Kamp Malzemeleri</option><option value="Ayakkabı">Ayakkabı</option><option value="Aksesuarlar">Aksesuarlar</option><option value="Çocuk Giyim">Çocuk Giyim</option><option value="Diğer">Diğer</option></select><div id="sizeSelectContainer" style="display:none;margin-bottom:15px;"><label style="display:block;margin-bottom:10px;font-weight:bold;color:#333;">Yaş Gruplarını Seçin:</label><div id="sizeCheckboxes" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(110px,1fr));gap:8px;padding:12px;border:1px solid #ddd;border-radius:6px;background:#f9f9f9;"></div></div><input type="text" id="image" placeholder="Resim URL (opsiyonel)"><input type="text" id="barcode" placeholder="Barkod (otomatik oluşturulabilir)"><textarea id="description" placeholder="Açıklama (opsiyonel)"></textarea><button type="submit" class="btn btn-primary">Ürün Ekle</button></form><div id="message"></div></div><style>.form-container{max-width:600px;margin:0 auto;background:white;padding:30px;border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.1)}h2{margin-bottom:25px;color:#333}.form-container input,.form-container select,.form-container textarea{width:100%;padding:12px;margin-bottom:15px;border:1px solid #ddd;border-radius:6px;font-size:14px;box-sizing:border-box;font-family:inherit}.form-container textarea{min-height:100px;resize:vertical}#sizeCheckboxes label{display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px;padding:4px 6px;border-radius:4px;transition:background 0.2s}#sizeCheckboxes label:hover{background:#e0f2fe}#sizeCheckboxes input[type="checkbox"]{width:auto;margin:0;padding:0;cursor:pointer}#message{margin-top:20px;padding:15px;border-radius:6px;display:none}#message.success{background:#d1fae5;color:#065f46;border:1px solid #6ee7b7;display:block}#message.error{background:#fee2e2;color:#991b1b;border:1px solid #fca5a5;display:block}</style><script>function updateSizeOptions(){const category=document.getElementById('category').value;const container=document.getElementById('sizeSelectContainer');const checkboxDiv=document.getElementById('sizeCheckboxes');checkboxDiv.innerHTML='';if(category==='Çocuk Giyim'){const ages=Array.from({length:13},((_,i)=>(4+i)+' Yaş'));ages.forEach(age=>{const label=document.createElement('label');const cb=document.createElement('input');cb.type='checkbox';cb.value=age;cb.className='size-checkbox';label.appendChild(cb);label.appendChild(document.createTextNode(age));checkboxDiv.appendChild(label)});container.style.display='block'}else{container.style.display='none'}}document.getElementById('productForm').addEventListener('submit',async(e)=>{e.preventDefault();const form=document.getElementById('productForm');const messageDiv=document.getElementById('message');const category=document.getElementById('category').value;const selectedSizes=Array.from(document.querySelectorAll('.size-checkbox:checked')).map(cb=>cb.value);try{const response=await fetch('/api/products',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:document.getElementById('name').value,price:document.getElementById('price').value,category:category,image:document.getElementById('image').value,barcode:document.getElementById('barcode').value,description:document.getElementById('description').value,customSizes:selectedSizes.length>0?selectedSizes:undefined})});const data=await response.json();if(response.ok){messageDiv.className='success';messageDiv.textContent='✅ '+data.message;form.reset();document.getElementById('sizeSelectContainer').style.display='none';setTimeout(()=>{messageDiv.style.display='none'},3000)}else{messageDiv.className='error';messageDiv.textContent='❌ '+data.message}}catch(error){messageDiv.className='error';messageDiv.textContent='❌ Hata: '+error.message}});<\/script>` 
}) %>
